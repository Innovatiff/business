---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { QUESTIONS, FINDER_SECTIONS, type MatchRecord } from '../data/finder';
import { CATEGORY_MAP } from '../data/categories';

const all = await getCollection('businesses');

// Build the compact records the client uses for matching + display.
const records: MatchRecord[] = all.map((b) => {
  const d = b.data;
  return {
    slug: d.slug,
    title: d.title,
    category: d.category,
    categoryName: CATEGORY_MAP[d.category]?.shortName ?? d.category,
    startupCostLow: d.startupCostLow,
    startupCostHigh: d.startupCostHigh,
    monthlyEarningsLow: d.monthlyEarningsLow,
    monthlyEarningsHigh: d.monthlyEarningsHigh,
    timeToFirstIncome: d.timeToFirstIncome,
    difficultyLevel: d.difficultyLevel,
    bestFor: d.bestFor,
    biggestRisk: d.biggestRisk,
    speedToIncome: d.speedToIncome,
    minWeeklyHours: d.minWeeklyHours,
    skills: d.skills,
    workLocations: d.workLocations,
    priorities: d.priorities,
    noExperienceRequired: d.noExperienceRequired,
    partTimeFriendly: d.partTimeFriendly,
  };
});

// Group questions by section for the stepped wizard.
const steps = FINDER_SECTIONS.map((section) => ({
  section,
  questions: QUESTIONS.filter((q) => q.section === section),
}));
---

<BaseLayout
  title="Find My Business: An Honest Business Finder"
  description="Answer a few honest questions about your budget, time, skills, and situation. We will only show businesses that realistically fit you, no account, no stored answers, no hype."
  path="/find-my-business"
>
  <div class="container finder-head">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Find My Business' }]} />
    <h1>Find the right business for your real life</h1>
    <p class="lead">
      Answer honestly. The more accurate your answers, the more useful your results. We will only
      show businesses that genuinely fit your budget, time, and situation, never the ones you
      can't realistically start.
    </p>
    <p class="finder-privacy">
      No account required. We do not store your answers, everything runs in your browser and
      disappears when you close the page.
    </p>
  </div>

  <div class="container finder-shell">
    <!-- Embedded match data (no tracking, no network calls) -->
    <script type="application/json" id="finder-records" is:inline set:html={JSON.stringify(records)}></script>

    <form id="finder" class="finder card" novalidate>
      <div class="finder-progress" aria-hidden="true">
        <div class="finder-progress-bar" id="progress-bar"></div>
      </div>
      <p class="finder-step-count"><span id="step-now">1</span> of {steps.length + 1}</p>

      {steps.map((step, si) => (
        <fieldset class="finder-stepview" data-step={si} hidden={si !== 0}>
          <legend class="finder-section-title">{step.section}</legend>
          {step.questions.map((q) => (
            <div class="finder-q" data-qid={q.id} data-type={q.type}>
              <p class="finder-prompt">{q.prompt}</p>
              {q.help && <p class="finder-help">{q.help}</p>}
              <div class="finder-options">
                {q.options.map((opt) => (
                  <label class="opt">
                    <input
                      type={q.type === 'multi' ? 'checkbox' : 'radio'}
                      name={q.id}
                      value={opt.value}
                    />
                    <span class="opt-label">{opt.label}</span>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </fieldset>
      ))}

      <!-- Results step -->
      <div class="finder-stepview" data-step={steps.length} hidden>
        <h2 class="finder-results-title">Your honest matches</h2>
        <p class="finder-results-sub" id="results-sub"></p>
        <div class="finder-share" id="share-row" hidden>
          <button type="button" class="btn btn-secondary btn-sm" id="share-btn">🔗 Copy shareable link</button>
          <span class="finder-share-status" id="share-status" role="status"></span>
        </div>
        <div id="results"></div>
        <div id="no-results" hidden>
          <div class="noresults card">
            <h3>No honest match within those exact constraints</h3>
            <p>
              That usually means the budget, time, or timeframe is tighter than the businesses
              currently in our library. Rather than show you something that won't realistically
              work, we'd rather tell you straight. Try loosening one answer, often a slightly
              higher budget or a longer timeframe opens up strong options.
            </p>
            <button type="button" class="btn btn-secondary" data-action="restart">Adjust my answers</button>
          </div>
        </div>
      </div>

      <div class="finder-nav">
        <button type="button" class="btn btn-secondary" id="back-btn" hidden>← Back</button>
        <span class="finder-validation" id="validation" role="alert"></span>
        <span class="finder-autohint" id="auto-hint">Choose an answer and we'll move you along automatically.</span>
        <button type="button" class="btn btn-primary" id="next-btn" hidden>Continue →</button>
        <button type="button" class="btn btn-secondary" id="restart-btn" hidden>Start over</button>
      </div>
    </form>

    <p class="finder-foot muted">
      These matches are honest estimates to help you decide, not guarantees. Always read the full
      business page and do your own research before spending money.
    </p>
  </div>
</BaseLayout>

<style>
  .finder-head {
    padding-top: var(--space-8);
    max-width: var(--container-narrow);
  }
  .finder-head h1 {
    margin-top: 0.75rem;
  }
  .finder-privacy {
    font-size: 0.9rem;
    color: var(--muted);
    border-left: 3px solid var(--green);
    padding-left: 0.85rem;
  }
  .finder-shell {
    max-width: 780px;
    padding-bottom: var(--space-8);
  }
  .finder {
    padding: 1.75rem;
  }
  .finder-progress {
    height: 6px;
    background: var(--border);
    border-radius: 999px;
    overflow: hidden;
  }
  .finder-progress-bar {
    height: 100%;
    width: 20%;
    background: var(--green);
    border-radius: 999px;
    transition: width 0.25s ease;
  }
  .finder-step-count {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--muted);
    font-weight: 700;
    margin: 0.6rem 0 1.25rem;
  }
  .finder-stepview {
    border: none;
    padding: 0;
    margin: 0;
  }
  .finder-section-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.02em;
    padding: 0;
    margin-bottom: 1.25rem;
  }
  .finder-q {
    margin-bottom: 1.75rem;
  }
  .finder-prompt {
    font-weight: 700;
    color: var(--navy);
    font-size: 1.08rem;
    margin-bottom: 0.3rem;
  }
  .finder-help {
    font-size: 0.88rem;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .finder-options {
    display: grid;
    gap: 0.55rem;
  }
  .opt {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.12s ease, background 0.12s ease;
  }
  .opt:hover {
    border-color: var(--slate);
    background: var(--surface);
  }
  .opt input {
    width: 18px;
    height: 18px;
    accent-color: var(--green);
    flex: none;
  }
  .opt:has(input:checked) {
    border-color: var(--green);
    background: var(--green-tint);
  }
  .opt-label {
    font-size: 0.98rem;
    color: var(--slate);
  }
  .finder-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .finder-nav #next-btn,
  .finder-nav #auto-hint {
    margin-left: auto;
  }
  .finder-validation {
    color: var(--red);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .finder-autohint {
    color: var(--muted);
    font-size: 0.85rem;
    text-align: right;
  }
  .finder-foot {
    margin-top: 1rem;
    font-size: 0.85rem;
  }
  /* Results */
  .finder-results-title {
    margin-bottom: 0.4rem;
  }
  .finder-results-sub {
    color: var(--slate);
    margin-bottom: 1rem;
  }
  .finder-share {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .finder-share-status {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--green-dark);
  }
  .noresults {
    padding: 1.5rem;
    border-left: 4px solid var(--amber);
  }
  @media (max-width: 560px) {
    .finder-nav {
      flex-wrap: wrap;
    }
  }
</style>

<!--
  Result cards are injected via innerHTML at runtime. Astro's scoped styles only
  attach to elements that exist at build time, so these card styles must be
  GLOBAL or the matches render unstyled. They are scoped under #results so they
  cannot leak anywhere else on the site.
-->
<style is:global>
  #results .result {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem;
    margin-bottom: 1rem;
    background: var(--card);
    box-shadow: var(--shadow-sm);
  }
  #results .result-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  #results .result-rank {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  #results .result h3 {
    margin: 0.15rem 0 0.4rem;
    font-size: 1.3rem;
  }
  #results .result-best {
    margin: 0;
    color: var(--slate);
    font-size: 0.95rem;
  }
  #results .result-why {
    background: var(--green-tint);
    border-radius: var(--radius-sm);
    padding: 0.8rem 1rem;
    margin: 0.9rem 0;
  }
  #results .result-why-title {
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--green-dark);
    font-weight: 700;
  }
  #results .result-why ul {
    margin: 0.4rem 0 0;
    padding-left: 1.1rem;
    color: var(--slate);
    font-size: 0.92rem;
  }
  #results .result-why li {
    margin: 0.15rem 0;
  }
  #results .result-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 0.9rem 0;
    padding: 0.9rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  #results .result-stats dt {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    font-weight: 700;
  }
  #results .result-stats dd {
    margin: 0.2rem 0 0;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--navy);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  #results .result-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  #results .result-risk {
    font-size: 0.85rem;
    color: var(--muted);
    max-width: 48ch;
  }
  @media (max-width: 560px) {
    #results .result-stats {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    #results .result-foot .btn {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>

<script>
  import { rankBusinesses, type MatchRecord, type Answers } from '../data/finder';

  // Cast to non-null for typing; the `if (form)` below is the runtime guard.
  const form = document.getElementById('finder') as HTMLFormElement;
  if (form) {
    const recordsEl = document.getElementById('finder-records');
    const records: MatchRecord[] = recordsEl ? JSON.parse(recordsEl.textContent || '[]') : [];

    const stepviews = Array.from(form.querySelectorAll<HTMLElement>('.finder-stepview'));
    const totalSteps = stepviews.length; // includes results step
    const lastQuestionStep = totalSteps - 2;
    const resultsStep = totalSteps - 1;

    const backBtn = document.getElementById('back-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;
    const autoHint = document.getElementById('auto-hint') as HTMLElement;
    const progressBar = document.getElementById('progress-bar') as HTMLElement;
    const stepNow = document.getElementById('step-now') as HTMLElement;
    const validation = document.getElementById('validation') as HTMLElement;

    let current = 0;
    let advanceTimer: number | undefined;

    const money = (n: number) => '$' + Math.round(n).toLocaleString('en-US');
    const escapeHtml = (s: string) =>
      s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string,
      );

    // A step needs a manual "Continue" button only when it has a multi-select
    // question (we can't tell when the user is finished ticking boxes). Every
    // single-choice step advances on its own the instant it's answered.
    const stepIsManual = (step: number) => !!stepviews[step].querySelector('[data-type="multi"]');

    function stepComplete(step: number): boolean {
      const view = stepviews[step];
      for (const q of Array.from(view.querySelectorAll<HTMLElement>('.finder-q'))) {
        if (q.dataset.type === 'single' && !view.querySelector(`input[name="${q.dataset.qid}"]:checked`)) {
          return false;
        }
      }
      return true;
    }

    function show(step: number) {
      if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = undefined; }
      current = step;
      stepviews.forEach((sv, i) => (sv.hidden = i !== step));
      const pct = ((step + 1) / totalSteps) * 100;
      progressBar.style.width = pct + '%';
      stepNow.textContent = String(step + 1);
      const onResults = step === resultsStep;
      backBtn.hidden = step === 0 || onResults;
      nextBtn.hidden = onResults || !stepIsManual(step);
      restartBtn.hidden = !onResults;
      autoHint.hidden = onResults || stepIsManual(step);
      validation.textContent = '';
      window.scrollTo({ top: form.getBoundingClientRect().top + window.scrollY - 90, behavior: 'smooth' });
    }

    // Move to the next question step, or straight to the matches after the last.
    function advanceFrom(step: number) {
      if (step >= lastQuestionStep) {
        renderResults();
        show(resultsStep);
      } else {
        show(step + 1);
      }
    }

    function collectAnswers(): Answers {
      const fd = new FormData(form);
      return {
        budget: (fd.get('budget') as string) || undefined,
        hours: (fd.get('hours') as string) || undefined,
        deadline: (fd.get('deadline') as string) || undefined,
        skills: fd.getAll('skills') as string[],
        location: (fd.get('location') as string) || undefined,
        priority: (fd.get('priority') as string) || undefined,
        concern: (fd.get('concern') as string) || undefined,
      };
    }

    function renderResults() {
      const answers = collectAnswers();
      const scored = rankBusinesses(answers, records).slice(0, 8);
      const resultsEl = document.getElementById('results') as HTMLElement;
      const noResults = document.getElementById('no-results') as HTMLElement;
      const sub = document.getElementById('results-sub') as HTMLElement;

      const shareRow = document.getElementById('share-row') as HTMLElement;
      if (scored.length === 0) {
        resultsEl.innerHTML = '';
        noResults.hidden = false;
        sub.textContent = '';
        if (shareRow) shareRow.hidden = true;
        return;
      }
      noResults.hidden = true;
      if (shareRow) shareRow.hidden = false;
      sub.textContent = `Based on your answers, here ${scored.length === 1 ? 'is' : 'are'} ${scored.length} ${
        scored.length === 1 ? 'business' : 'businesses'
      } that honestly fit, ranked by how well they match. We always show the full realistic range, not the best case.`;

      resultsEl.innerHTML = scored
        .map((s, i) => {
          const r = s.record;
          const reasons = s.reasons.map((x) => `<li>${escapeHtml(x)}</li>`).join('');
          return `
          <article class="result">
            <div class="result-head">
              <div>
                <span class="result-rank">Match #${i + 1} · ${escapeHtml(r.categoryName)}</span>
                <h3>${escapeHtml(r.title)}</h3>
                <p class="result-best">${escapeHtml(r.bestFor)}</p>
              </div>
              <span class="badge badge-${r.difficultyLevel.toLowerCase()}">${escapeHtml(r.difficultyLevel)}</span>
            </div>
            <div class="result-why">
              <span class="result-why-title">Why this fits you</span>
              <ul>${reasons}</ul>
            </div>
            <dl class="result-stats">
              <div><dt>Startup cost</dt><dd>${r.startupCostLow === 0 ? 'Free' : money(r.startupCostLow)} – ${money(r.startupCostHigh)}</dd></div>
              <div><dt>Monthly earnings</dt><dd>${money(r.monthlyEarningsLow)} – ${money(r.monthlyEarningsHigh)}</dd></div>
              <div><dt>First income</dt><dd>${escapeHtml(r.timeToFirstIncome)}</dd></div>
            </dl>
            <div class="result-foot">
              <span class="result-risk"><strong>Biggest risk:</strong> ${escapeHtml(r.biggestRisk)}</span>
              <a class="btn btn-primary" href="/businesses/${r.slug}/">Read the full breakdown →</a>
            </div>
          </article>`;
        })
        .join('');
    }

    // Auto-advance single-choice steps the moment they are fully answered.
    // A short debounce lets keyboard users arrow through radios without jumping,
    // and gives a beat of visual feedback on the chosen option before moving on.
    form.addEventListener('change', (e) => {
      const view = stepviews[current];
      if (!view || !view.contains(e.target as Node)) return;
      validation.textContent = '';
      if (stepIsManual(current)) return; // multi-select steps use the Continue button
      if (advanceTimer) clearTimeout(advanceTimer);
      const scheduledStep = current;
      if (stepComplete(scheduledStep)) {
        advanceTimer = window.setTimeout(() => {
          if (current === scheduledStep && stepComplete(scheduledStep)) advanceFrom(scheduledStep);
        }, 420);
      }
    });

    // Continue button only appears on the multi-select step.
    nextBtn.addEventListener('click', () => advanceFrom(current));
    backBtn.addEventListener('click', () => show(Math.max(0, current - 1)));

    function restart() {
      form.reset();
      show(0);
    }
    restartBtn.addEventListener('click', restart);
    form.querySelectorAll('[data-action="restart"]').forEach((b) => b.addEventListener('click', restart));

    // Shareable results: encode the answers as short query params.
    const shareBtn = document.getElementById('share-btn');
    const shareStatus = document.getElementById('share-status');
    function buildShareUrl(): string {
      const a = collectAnswers();
      const params = new URLSearchParams();
      if (a.budget) params.set('b', a.budget);
      if (a.hours) params.set('h', a.hours);
      if (a.deadline) params.set('d', a.deadline);
      if (a.skills && a.skills.length) params.set('s', a.skills.join(','));
      if (a.location) params.set('l', a.location);
      if (a.priority) params.set('p', a.priority);
      if (a.concern) params.set('c', a.concern);
      return location.origin + location.pathname + '?' + params.toString();
    }
    shareBtn?.addEventListener('click', async () => {
      const url = buildShareUrl();
      try {
        await navigator.clipboard.writeText(url);
        if (shareStatus) shareStatus.textContent = 'Link copied!';
      } catch {
        history.replaceState(null, '', url);
        if (shareStatus) shareStatus.textContent = 'Link ready in your address bar';
      }
      window.setTimeout(() => {
        if (shareStatus) shareStatus.textContent = '';
      }, 2600);
    });

    // Deep-link: if the URL carries answers, prefill the form and jump to matches.
    function applyFromUrl(): boolean {
      const q = new URLSearchParams(location.search);
      if (![...q.keys()].length) return false;
      const setRadio = (name: string, val: string | null) => {
        if (!val) return;
        const el = form.querySelector<HTMLInputElement>(`input[name="${name}"][value="${CSS.escape(val)}"]`);
        if (el) el.checked = true;
      };
      setRadio('budget', q.get('b'));
      setRadio('hours', q.get('h'));
      setRadio('deadline', q.get('d'));
      setRadio('location', q.get('l'));
      setRadio('priority', q.get('p'));
      setRadio('concern', q.get('c'));
      (q.get('s') || '').split(',').filter(Boolean).forEach((v) => {
        const el = form.querySelector<HTMLInputElement>(`input[name="skills"][value="${CSS.escape(v)}"]`);
        if (el) el.checked = true;
      });
      return true;
    }

    if (applyFromUrl()) {
      renderResults();
      show(resultsStep);
    } else {
      show(0);
    }
  }
</script>
