---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config';
---
<BaseLayout
  title="Contact Honestly Profitable"
  description="Get in touch with Honestly Profitable — corrections, questions, feedback, or to flag an out-of-date number on a business page."
  path="/contact"
>
  <div class="container container-narrow page-head">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <h1>Contact us</h1>
    <p class="lead">Questions, corrections, and feedback are genuinely welcome.</p>
  </div>

  <div class="container container-narrow page-body">
    <p>
      We are a small, independent reference site, and accuracy matters to us. If you spot a number
      that looks wrong or out of date, run one of these businesses and want to share real figures,
      or just have a question, we want to hear from you.
    </p>

    <div class="contact-card card">
      <span class="contact-label">Email</span>
      <a class="contact-email" href={`mailto:${SITE.email}`}>{SITE.email}</a>
    </div>

    <h2>Helpful things to include</h2>
    <ul>
      <li>If it is a correction: the page, the figure you are flagging, and a source if you have one.</li>
      <li>If you operate the business: rough real numbers (costs, earnings, time to first income) and your region.</li>
      <li>If it is a general question: as much detail about your situation as you are comfortable sharing.</li>
    </ul>

    <p>
      We read everything, though we cannot always reply individually. We do not provide personalized
      financial, legal, or investment advice — see our <a href="/disclaimer">disclaimer</a>. To
      suggest a whole new business for the site, use the
      <a href="/submit-a-business-idea">submit a business idea</a> page.
    </p>
  </div>
</BaseLayout>

<style>
  .contact-card {
    padding: 1.5rem;
    text-align: center;
    margin: 1.5rem 0;
  }
  .contact-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .contact-email {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--green-dark);
  }
</style>
