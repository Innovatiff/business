---
/**
 * "Created by the Honestly Profitable Editorial Team" byline.
 *   - variant="full"    → brand mark + linked team name + optional review date
 *                         (used at the top of every article).
 *   - variant="compact" → small brand mark + team name, no link
 *                         (used on article cards).
 * The breakdowns are produced by the editorial team, so the byline uses the
 * site's mark rather than one person's photo.
 */
import { EDITORIAL } from '../data/author';

interface Props {
  variant?: 'full' | 'compact';
  /** Optional "Reviewed <date>" shown on the full variant. */
  date?: string;
}
const { variant = 'full', date } = Astro.props;
---

{variant === 'compact' ? (
  <span class="ab ab-compact">
    <span class="ab-mark ab-mark-sm" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 17l5-5 4 4 8-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 7h-4M20 7v4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
    <span class="ab-text">{EDITORIAL.byline}</span>
  </span>
) : (
  <div class="ab ab-full">
    <span class="ab-mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 17l5-5 4 4 8-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 7h-4M20 7v4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
    <span class="ab-lines">
      <span class="ab-by">Created by the <a href={EDITORIAL.url}>Honestly Profitable Editorial Team</a></span>
      <span class="ab-meta">
        Independent research, no courses to sell{date && <> · Reviewed {date}</>}
      </span>
    </span>
  </div>
)}

<style>
  .ab-full {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .ab-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    flex: none;
    border-radius: 10px;
    background: #0f172a;
    color: var(--green);
  }
  .ab-mark svg {
    width: 24px;
    height: 24px;
  }
  .ab-lines {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .ab-by {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--navy);
  }
  .ab-by a {
    color: var(--navy);
  }
  .ab-by a:hover {
    color: var(--green-dark);
  }
  .ab-meta {
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* Compact — for cards */
  .ab-compact {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .ab-mark-sm {
    width: 22px;
    height: 22px;
    border-radius: 6px;
  }
  .ab-mark-sm svg {
    width: 13px;
    height: 13px;
  }
  .ab-text {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 600;
  }
</style>
