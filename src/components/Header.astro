---
import { SITE, PRIMARY_NAV } from '../config';
const path = Astro.url.pathname.replace(/\/$/, '');
// Exact match, or a true sub-path (with trailing slash) so /businesses doesn't
// falsely light up on /businesses-under-500.
const isActive = (href?: string) =>
  !!href && (path === href || (href !== '/' && path.startsWith(href + '/')));
const groupsActive = (groups?: { items: { href: string }[] }[]) =>
  !!groups && groups.some((g) => g.items.some((c) => isActive(c.href)));
// "Browse" is active on the all-businesses page and any budget/skill/time filter.
const browseActive = (item: { href?: string; groups?: { items: { href: string }[] }[] }) =>
  groupsActive(item.groups) || isActive('/businesses');
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 17l5-5 4 4 8-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M20 7h-4M20 7v4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="brand-text">Honestly <span class="brand-accent">Profitable</span></span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {PRIMARY_NAV.map((item) =>
        item.groups ? (
          <div class="nav-item">
            <button
              type="button"
              class:list={['nav-link', 'nav-trigger', { active: browseActive(item) }]}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {item.label}
              <ion-icon name="chevron-down-outline" class="nav-caret" aria-hidden="true"></ion-icon>
            </button>
            <div class="dropdown-menu mega">
              <div class="mega-cols">
                {item.groups.map((g) => (
                  <div class="mega-col">
                    <a href={g.href} class="mega-heading">
                      {g.icon && <ion-icon name={g.icon} aria-hidden="true"></ion-icon>}
                      {g.heading}
                    </a>
                    <ul role="menu">
                      {g.items.map((c) => (
                        <li role="none">
                          <a role="menuitem" href={c.href} class:list={['dropdown-link', { active: isActive(c.href) }]}>
                            {c.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
              <a href="/businesses" class="mega-all">
                <ion-icon name="grid-outline" aria-hidden="true"></ion-icon>
                <span>Browse all businesses</span>
                <ion-icon name="arrow-forward-outline" aria-hidden="true"></ion-icon>
              </a>
            </div>
          </div>
        ) : (
          <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
            {item.label}
          </a>
        ),
      )}
    </nav>

    <div class="header-actions">
      <a href="/compare" class="icon-btn saved-link" data-saved-link aria-label="Saved businesses to compare" title="Saved / compare">
        <ion-icon name="heart-outline" aria-hidden="true"></ion-icon>
        <span class="saved-count" data-saved-count hidden>0</span>
      </a>
      <button class="icon-btn theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle light / dark">
        <ion-icon name="moon-outline" class="icon-moon" aria-hidden="true"></ion-icon>
        <ion-icon name="sunny-outline" class="icon-sun" aria-hidden="true"></ion-icon>
      </button>
      <a href="/find-my-business" class="btn btn-primary btn-cta">
        <ion-icon name="compass-outline" aria-hidden="true"></ion-icon>
        Find My Business
      </a>
      <button class="icon-btn nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-nav">
        <ion-icon name="menu-outline" class="icon-open" aria-hidden="true"></ion-icon>
        <ion-icon name="close-outline" class="icon-close" aria-hidden="true"></ion-icon>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" id="mobile-nav" aria-label="Mobile" hidden>
    <a href="/businesses" class:list={['m-link', { active: isActive('/businesses') }]}>
      <ion-icon name="grid-outline" aria-hidden="true"></ion-icon><span>All businesses</span>
    </a>
    {PRIMARY_NAV.map((item) =>
      item.groups ? (
        // Mobile: keep the filters as flat, separate buttons (no dropdown).
        item.groups.map((g) => (
          <a href={g.href} class:list={['m-link', { active: groupsActive([g]) }]}>
            <ion-icon name={g.icon} aria-hidden="true"></ion-icon><span>By {g.heading}</span>
          </a>
        ))
      ) : (
        <a href={item.href} class:list={['m-link', { active: isActive(item.href) }]}>
          <ion-icon name={item.icon} aria-hidden="true"></ion-icon><span>{item.label}</span>
        </a>
      ),
    )}
    <a href="/compare" class="m-link" data-saved-link>
      <ion-icon name="heart-outline" aria-hidden="true"></ion-icon><span>Saved / compare</span>
    </a>
    <a href="/find-my-business" class="btn btn-primary m-cta">
      <ion-icon name="compass-outline" aria-hidden="true"></ion-icon>
      Find My Business
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 250, 249, 0.92);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  :global(:root[data-theme='dark']) .site-header {
    background: rgba(10, 17, 32, 0.9);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--navy);
    white-space: nowrap;
    margin-right: auto;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: #0f172a;
    color: var(--green);
  }
  .brand-accent {
    color: var(--green-dark);
  }

  /* ---- Shared square icon buttons (saved / theme / hamburger) ---- */
  .icon-btn {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--slate);
    cursor: pointer;
    flex: none;
    font-size: 20px;
  }
  .icon-btn:hover {
    color: var(--navy);
    border-color: var(--slate);
    text-decoration: none;
  }
  .saved-link {
    position: relative;
  }
  .saved-link:hover {
    color: var(--red);
    border-color: var(--red);
  }
  .saved-count {
    position: absolute;
    top: -7px;
    right: -7px;
    min-width: 19px;
    height: 19px;
    padding: 0 4px;
    background: var(--red);
    color: #fff;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    font-family: var(--font-display);
    display: grid;
    place-items: center;
    line-height: 1;
  }
  .theme-toggle .icon-sun {
    display: none;
  }
  :global(:root[data-theme='dark']) .theme-toggle .icon-sun {
    display: block;
  }
  :global(:root[data-theme='dark']) .theme-toggle .icon-moon {
    display: none;
  }

  /* ---- Desktop nav ---- */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    margin-right: 0.5rem;
  }
  .nav-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--slate);
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--navy);
    background: var(--surface);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--green-dark);
  }

  /* ---- Desktop dropdown ---- */
  .nav-item {
    position: relative;
    display: inline-flex;
  }
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .nav-caret {
    font-size: 0.85rem;
    opacity: 0.7;
    transition: transform 0.18s ease;
  }
  .nav-item:hover .nav-caret,
  .nav-trigger[aria-expanded='true'] .nav-caret {
    transform: rotate(180deg);
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    margin: 0;
    padding: 0.85rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    z-index: 120;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
  }
  .nav-item:hover .dropdown-menu,
  .nav-item:focus-within .dropdown-menu,
  .nav-trigger[aria-expanded='true'] + .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  /* Grouped (mega) dropdown: three columns + a full-width "browse all" footer */
  .dropdown-menu.mega {
    left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 560px;
  }
  .mega-cols {
    display: flex;
    gap: 0.4rem;
  }
  .mega-col {
    flex: 1;
    min-width: 168px;
  }
  .mega-col + .mega-col {
    border-left: 1px solid var(--border);
    padding-left: 0.5rem;
  }
  .mega-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mega-col li {
    margin: 0;
  }
  .mega-heading {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 700;
    padding: 0.1rem 0.7rem 0.5rem;
  }
  .mega-heading:hover {
    color: var(--green-dark);
    text-decoration: none;
  }
  .mega-heading ion-icon {
    font-size: 0.95rem;
  }
  .dropdown-link {
    display: block;
    padding: 0.5rem 0.7rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--slate);
    white-space: nowrap;
  }
  .dropdown-link:hover {
    background: var(--surface);
    color: var(--navy);
    text-decoration: none;
  }
  .dropdown-link.active {
    color: var(--green-dark);
    background: var(--green-tint);
  }
  .mega-all {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    border-radius: var(--radius-sm);
    background: var(--surface);
    border: 1px solid var(--border);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--navy);
  }
  .mega-all ion-icon:first-child {
    color: var(--green-dark);
    font-size: 1.05rem;
  }
  .mega-all span {
    flex: 1;
  }
  .mega-all ion-icon:last-child {
    font-size: 0.9rem;
    transition: transform 0.15s ease;
  }
  .mega-all:hover {
    border-color: var(--green);
    text-decoration: none;
  }
  .mega-all:hover ion-icon:last-child {
    transform: translateX(3px);
  }

  /* ---- Actions cluster ---- */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-cta {
    gap: 0.4rem;
  }
  .btn-cta ion-icon {
    font-size: 1.05rem;
  }
  .nav-toggle {
    display: none;
  }
  .nav-toggle .icon-close {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .icon-open {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  /* ---- Mobile nav ---- */
  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem 1.25rem 1.5rem;
    border-top: 1px solid var(--border);
    background: var(--card);
  }
  .m-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0.6rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    color: var(--slate);
  }
  .m-link ion-icon {
    font-size: 1.3rem;
    color: var(--muted);
    flex: none;
  }
  .m-link:hover,
  .m-link:active {
    background: var(--surface);
    color: var(--navy);
    text-decoration: none;
  }
  .m-link.active {
    color: var(--green-dark);
    background: var(--green-tint);
  }
  .m-link.active ion-icon {
    color: var(--green-dark);
  }
  .m-cta {
    margin-top: 0.9rem;
    justify-content: center;
    gap: 0.45rem;
    font-size: 1rem;
    padding-block: 0.85rem;
  }
  .m-cta ion-icon {
    font-size: 1.15rem;
  }

  @media (max-width: 880px) {
    .nav-desktop,
    .btn-cta {
      display: none;
    }
    .nav-toggle {
      display: grid;
    }
    .nav-mobile:not([hidden]) {
      display: flex;
    }
  }
  @media (max-width: 560px) {
    /* Phones: show only the logo mark (dark + green trend), hide the wordmark
       so the action buttons have room and the bar never feels cramped. The
       anchor keeps its aria-label, so the site name is still announced. */
    .brand-text {
      display: none;
    }
    .brand-mark {
      width: 38px;
      height: 38px;
    }
    .header-actions {
      gap: 0.4rem;
    }
  }
</style>

<script>
  // Light / dark theme toggle (initial theme is set pre-paint in <head>).
  const themeToggle = document.querySelector<HTMLButtonElement>('.theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch (e) {
      /* ignore */
    }
  });

  // Mobile menu toggle
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });

  // Desktop dropdown disclosure (click + keyboard; hover handled by CSS)
  const triggers = Array.from(document.querySelectorAll<HTMLButtonElement>('.nav-trigger'));
  const closeAll = (except?: HTMLButtonElement) =>
    triggers.forEach((t) => t !== except && t.setAttribute('aria-expanded', 'false'));

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = trigger.getAttribute('aria-expanded') === 'true';
      closeAll(trigger);
      trigger.setAttribute('aria-expanded', String(!open));
    });
  });

  document.addEventListener('click', () => closeAll());
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAll();
      (document.activeElement as HTMLElement | null)?.blur();
    }
  });
</script>
