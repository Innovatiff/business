---
export interface Props {
  items: string[];
}
const { items } = Astro.props;
---
<div class="getwrong">
  <ul>
    {items.map((item) => (
      <li>
        <span class="x" aria-hidden="true">✕</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .getwrong {
    background: var(--red-tint);
    border: 1px solid #fecaca;
    border-left: 4px solid var(--red);
    border-radius: var(--radius);
    padding: 1.1rem 1.4rem;
  }
  .getwrong ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .getwrong li {
    display: flex;
    gap: 0.7rem;
    margin: 0;
    color: var(--slate);
  }
  .x {
    flex: none;
    color: var(--red);
    font-weight: 800;
    line-height: 1.6;
  }
</style>
