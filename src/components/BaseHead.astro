---
/**
 * Global <head>. Single source of truth for SEO tags, Open Graph, and the
 * (currently disabled) AdSense script. After AdSense approval, set
 * PUBLIC_ADSENSE_ENABLED=true and PUBLIC_ADSENSE_CLIENT — the script then
 * loads site-wide automatically because this component is in the base layout.
 */
import { SITE, ADSENSE, SEO } from '../config';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  /** Path-only canonical, e.g. "/businesses/pressure-washing-business". */
  path?: string;
  /** Optional structured data objects (JSON-LD). */
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
  ogType?: string;
}

const { title, description, path = '', jsonLd = [], noindex = false, ogType = 'website' } = Astro.props;

// Canonical URLs carry a trailing slash (except the root) so they match the
// directory-format page Netlify serves with a 200 — sitemap, canonical tag,
// and served URL all agree, leaving no redirect for Google (or browsers) to hit.
const rawPath = path || Astro.url.pathname || '/';
const trimmed = rawPath.replace(/^\/+|\/+$/g, '');
const canonicalPath = trimmed ? `/${trimmed}/` : '/';
const canonical = new URL(canonicalPath, SITE.url).href;
const ogImage = new URL('/og-default.svg', SITE.url).href;
const fullTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Set the theme before first paint to avoid a flash of the wrong colors. -->
<script is:inline>
  (function () {
    try {
      var t = localStorage.getItem('theme');
      if (t !== 'dark' && t !== 'light') {
        t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      document.documentElement.dataset.theme = t;
    } catch (e) {}
  })();
</script>

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Google Search Console verification (set PUBLIC_GOOGLE_SITE_VERIFICATION) -->
{SEO.googleSiteVerification && (
  <meta name="google-site-verification" content={SEO.googleSiteVerification} />
)}

<!-- Open Graph -->
<meta property="og:site_name" content={SITE.name} />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={SITE.locale} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Icons & theme -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#0f172a" />

<!-- Ionicons web-component library, self-hosted under /vendor/ionicons (loader
     + only the SVGs the site uses). Vendored locally so the site stays fully
     self-contained — no external CDN request. The module script is deferred by
     default, so it never blocks first paint. -->
<script type="module" src="/vendor/ionicons/ionicons.esm.js"></script>

<!-- Performance hints -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Site-wide entity structured data (Organization + WebSite) -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: new URL('/favicon.svg', SITE.url).href,
    description: SITE.description,
  })}
/>
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    publisher: { '@type': 'Organization', name: SITE.name },
  })}
/>

<!-- Structured data -->
{
  jsonLd.map((obj) => (
    <script type="application/ld+json" set:html={JSON.stringify(obj)} />
  ))
}

<!--
  Google AdSense SITE CONNECTION. This must be present site-wide for Google to
  verify and review the site for approval; it displays no visible ads on its own
  (actual ad units are gated separately in AdSlot.astro until approval). Both the
  verification meta tag and the loader script are Google's recommended ways to
  connect a site.
-->
{
  ADSENSE.client && (
    <>
      <meta name="google-adsense-account" content={ADSENSE.client} />
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE.client}`}
        crossorigin="anonymous"
      />
    </>
  )
}
