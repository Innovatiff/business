---
/**
 * The one global layout. Every page renders inside this so the header, footer,
 * SEO head, and (post-approval) AdSense script apply site-wide.
 */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';

export interface Props {
  title: string;
  description: string;
  path?: string;
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
  ogType?: string;
}

const { title, description, path, jsonLd, noindex, ogType } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      path={path}
      jsonLd={jsonLd}
      noindex={noindex}
      ogType={ogType}
    />
    <Analytics />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Save-to-compare: a browser-only shortlist (no account, nothing sent to
      // us). Delegated so it covers save buttons anywhere, including the compare
      // page which re-renders its own list.
      const KEY = 'hp:saved';
      const read = (): Set<string> => {
        try {
          return new Set(JSON.parse(localStorage.getItem(KEY) || '[]'));
        } catch {
          return new Set();
        }
      };
      const write = (set: Set<string>) => {
        try {
          localStorage.setItem(KEY, JSON.stringify([...set]));
        } catch {
          /* ignore */
        }
      };
      const syncButtons = (set: Set<string>) => {
        document.querySelectorAll<HTMLElement>('[data-save]').forEach((btn) => {
          const s = btn.getAttribute('data-slug') || '';
          btn.setAttribute('aria-pressed', set.has(s) ? 'true' : 'false');
        });
      };
      const syncCount = (set: Set<string>) => {
        document.querySelectorAll<HTMLElement>('[data-saved-count]').forEach((el) => {
          el.textContent = String(set.size);
          el.hidden = set.size === 0;
        });
      };
      const refresh = () => {
        const set = read();
        syncButtons(set);
        syncCount(set);
        document.dispatchEvent(new CustomEvent('hp:saved-changed', { detail: [...set] }));
      };
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-save]');
        if (!btn) return;
        const s = btn.getAttribute('data-slug');
        if (!s) return;
        const set = read();
        set.has(s) ? set.delete(s) : set.add(s);
        write(set);
        refresh();
      });
      // Keep in sync across tabs.
      window.addEventListener('storage', (e) => {
        if (e.key === KEY) refresh();
      });
      refresh();
    </script>
  </body>
</html>
